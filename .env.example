# Copy this file to .env.local and fill in ONE provider's API key.
# ⚠️ Vite embeds VITE_* variables into the client bundle — anyone who opens
# DevTools can read them. Fine for demos/hackathons; for real production,
# proxy AI calls through a small backend instead.

# Which provider to use: OPENAI | GROQ | GEMINI  (legacy alias "GROK" = GROQ)
VITE_AI_PROVIDER=GROQ

# Provider API keys (only the one matching VITE_AI_PROVIDER is required)
VITE_OPENAI_API_KEY=
VITE_GROQ_API_KEY=
VITE_GEMINI_API_KEY=

# Optional overrides (sensible defaults are picked per provider)
# VITE_AI_MODEL=llama-3.3-70b-versatile
# VITE_AI_BASE_URL=https://api.groq.com/openai/v1/chat/completions
